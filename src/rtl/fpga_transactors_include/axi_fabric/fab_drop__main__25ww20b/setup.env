#Defacto
setenv HIDFT_VERSION 9.0.00.332r
setenv HIDFT_HOME /p/hdk/rtl/cad/x86-64_linux26/defacto/STAR-ADE/SoC_Compiler_ADE_$HIDFT_VERSION
setenv DEFACTO_LICENSE_FILE 2326@defacto02p.elic.intel.com:2326@defacto04p.elic.intel.com:2326@defacto03p.elic.intel.com:2326@defacto01p.elic.intel.com
