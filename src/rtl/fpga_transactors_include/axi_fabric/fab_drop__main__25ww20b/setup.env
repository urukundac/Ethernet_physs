#setenv EMUBUILD /nfs/site/eda/group/SYSNAME/emu/intel/emubuild/2.8.12/bin/emubuild
setenv EMUBUILD /nfs/site/eda/data/eda_0075/intel/emubuild/2.8.12/common/bin/emubuild


#Quartus
#setenv QUARTUS_VERSION 21.2.0.72
setenv QUARTUS_VERSION 22.4
setenv LM_LICENSE_FILE 1800@altera02p.elic.intel.com:1800@altera05p.elic.intel.com
setenv QUARTUS_INSTALL_DIR  /p/hdk/rtl/cad/x86-64_linux26/altera/quartus_prime_pro/$QUARTUS_VERSION/quartus
setenv QUARTUS_HOME $QUARTUS_INSTALL_DIR
setenv IP_ROOTDIR $QUARTUS_INSTALL_DIR/../ip
setenv QSYS_HOME $QUARTUS_INSTALL_DIR/sopc_builder
set path = ( /p/hdk/rtl/cad/x86-64_linux26/altera/quartus_prime_pro/$QUARTUS_VERSION/quartus/bin $path )
set path = ( /p/hdk/rtl/cad/x86-64_linux26/altera/quartus_prime_pro/$QUARTUS_VERSION/qsys/bin $path )

#HAPS
setenv SYNOPSYS_VERSION O-2018.06-SP2
setenv SYNOPSYS /p/hdk/rtl/cad/x86-64_linux26/synopsys/designcompiler/$SYNOPSYS_VERSION

setenv PROTOCOMPILER_VERSION T-2022.12-SP1-1
setenv PROTOCOMPILER_PATH /p/hdk/rtl/cad/x86-64_linux26/synopsys/protocompiler/$PROTOCOMPILER_VERSION
#set path = ( ${PROTOCOMPILER_PATH}/bin $PATH )

setenv VIVADO_VERSION 2022.1-ep7
setenv XILINX_VIVADO /p/hdk/rtl/cad/x86-64_linux26/xilinx/vivado/$VIVADO_VERSION
setenv VIVADO_PATH $XILINX_VIVADO


if ("$FPGA_FABRIC_ROOT" =~ "/nfs/site/disks/fpga_repos/*") then
  echo "\033[0;33mSkipping git updates\033[0m"
else
  #Checkout submodules
  git submodule update --init --recursive

  #To update submodule pointer
  #cd subIP/esr/
  #git pull origin esr_nvl_dev_1.0
endif

#Build Python env
if ("$FPGA_FABRIC_ROOT" =~ "/nfs/site/disks/fpga_repos/*") then
  echo "\033[0;33mSkipping generation of penv\033[0m"

  if (! -d "$VENV_PATH") then
    echo -e "\033[0;31mError: The virtual environment directory $VENV_PATH does not exist. This FCB drop appears broken!\033[0m"
    exit 1
  endif

  # Activate the virtual environment
  source "$VENV_PATH/bin/activate.csh"
else
  if (! -d "$VENV_PATH") then
    echo "\033[0;33mPython virtual environment not found. Creating one at $VENV_PATH ...\033[0m"
    python3.11.1 -m venv "$VENV_PATH" --prompt "fcb.venv"
  endif

  # Activate the virtual environment
  source "$VENV_PATH/bin/activate.csh"

  # Install required packages
  set REQUIREMENTS_FILE = "$FPGA_FABRIC_ROOT/python_dependencies.txt"

  if (-f "$REQUIREMENTS_FILE") then
      echo "Installing dependencies from $REQUIREMENTS_FILE ..."
      pip install -r "$REQUIREMENTS_FILE"
  else
      echo "No requirements file found at $REQUIREMENTS_FILE. Skipping package installation."
  endif
endif

# Add python search paths
if ($?PYTHONPATH) then
    setenv PYTHONPATH "${PYTHONPATH}:${FPGA_FABRIC_ROOT}"
else
    setenv PYTHONPATH "${FPGA_FABRIC_ROOT}"
endif

setenv PYTHONPATH "${PYTHONPATH}:${FPGA_FABRIC_ROOT}/lib/python"

#set path = ( $PYTHONUSERBASE/bin $path )
set path = ( $VENV_PATH/bin $path )

setenv PYTHONPATH $FPGA_FABRIC_ROOT/lib/python/verif/tests:$PYTHONPATH
setenv COCOTB_LIBPYTHON_DIR `cocotb-config --libpython | xargs dirname`
setenv LD_LIBRARY_PATH $LD_LIBRARY_PATH/:$COCOTB_LIBPYTHON_DIR

echo "\033[1;36mSetup Complete\033[0m"
echo ""
echo ""

