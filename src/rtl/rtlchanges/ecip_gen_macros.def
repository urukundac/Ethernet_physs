  /* ----  EOT Checker Macro ---- */
`define ECIP_GEN_EOT(__module_name, __name, __sig, __err_msg)   \
    `ifdef INTEL_SIMONLY                                        \
    `ifndef ECIP_GEN_DISABLE_ALL_EOT                            \
    `ifndef EOT_INIT_``__module_name                            \
      logic __module_name``_eot_start;                          \
      initial begin                                             \
        `ifndef EOT_START_``__module_name                       \
          __module_name``_eot_start = 1'b1;                     \
          `define EOT_START_``__module_name                     \
        `else                                                   \
          __module_name``_eot_start = 1'b0;                     \
        `endif                                                  \
      end                                                       \
      `define EOT_INIT_``__module_name                          \
    `endif                                                      \
    final begin                                                 \
      if ($test$plusargs(`"__module_name``_EOT_DIS`"))          \
           __module_name``_eot_start = 1'b0;                    \
                                                                \
      if(__module_name``_eot_start) begin                       \
            __name : assert(__sig) else $error(`"__err_msg`");  \
      end                                                       \
    end                                                         \
   `endif                                                       \
   `endif                                                       \
                                                       
