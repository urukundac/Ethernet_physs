set_port_assignment [get_ports I2C_RESETL\[7\] ] -protocol_instance_pin [get_hw_protocol_instance_pins $fpga8/mb6_fb2_ta1_eb1_DEFAULT_EB_PDS_QSFP+_R1/P1V8_QSFP_B_RESETL]
set_port_assignment [get_ports I2C_LPMODE\[7\] ] -protocol_instance_pin [get_hw_protocol_instance_pins $fpga8/mb6_fb2_ta1_eb1_DEFAULT_EB_PDS_QSFP+_R1/P1V8_QSFP_B_LPMODE]

